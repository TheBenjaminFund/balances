# Copy this file to .env and fill in values before running locally.

# Optional: Port to run the server on (defaults to 3000)
# PORT=3000

# Required: Admin bootstrap credentials
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=changeme123

# Required: Secret for signing JWTs (use a long random string)
JWT_SECRET=replace-with-a-long-random-string

# Local development only (Windows/Mac): path to your local Chrome/Chromium binary.
# On Render (Linux) leave this unset — @sparticuz/chromium handles it automatically.
# Example (Windows): CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Example (Mac):     CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#CHROME_PATH=


# Required in production so your SQLite DB persists across deploys/restarts.
# On Render, set this to the disk mount path you choose (e.g., /var/data) and
# attach a persistent disk at that same path.
DATA_DIR=./data